# Track only what the plugin needs to be installable as a marketplace plugin.
/*
!/.gitignore
!/.claude-plugin/
!/skills/

# OS / editor cruft
.DS_Store
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Local config / caches the skill creates at runtime
skills/metascope-slurm/.cache/
