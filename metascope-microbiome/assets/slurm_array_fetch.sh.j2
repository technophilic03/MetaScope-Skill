#!/bin/bash
{% if ACCOUNT %}#SBATCH --account={{ ACCOUNT }}
{% endif %}#SBATCH --partition={{ PARTITION }}
{% if PARTITION == "main" %}#SBATCH --requeue
{% endif %}#SBATCH --time={{ TIME }}
#SBATCH --mem={{ MEM }}
#SBATCH --cpus-per-task={{ CPUS }}
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --job-name={{ JOB_NAME }}-fetch
#SBATCH --output={{ LOG_DIR }}/slurm.%x.%A_%a.out
#SBATCH --error={{ LOG_DIR }}/slurm.%x.%A_%a.err
#SBATCH --array=0-{{ N_RUNS_MINUS_ONE }}{% if ARRAY_CONCURRENCY %}%{{ ARRAY_CONCURRENCY }}{% endif %}

# nf-core/metascopeprolifer FASTQ fetch (array mode)
# One array task per run from {{ RUNS_LIST }}
# Generated by metascope-microbiome skill — do not edit by hand.
# Generated: {{ GENERATED_AT }}

set -euo pipefail

module purge
{{ MODULE_LOADS }}

RUNS_LIST="{{ RUNS_LIST }}"
FASTQ_DIR="{{ FASTQ_DIR }}"
mkdir -p "$FASTQ_DIR" "{{ LOG_DIR }}"

# Pick this task's run accession (line N+1 of the runs file).
RUN=$(sed -n "$((SLURM_ARRAY_TASK_ID + 1))p" "$RUNS_LIST" | tr -d '[:space:]')
if [[ -z "$RUN" ]]; then
    echo "ERROR: empty run at array index $SLURM_ARRAY_TASK_ID in $RUNS_LIST" >&2
    exit 1
fi

# Skip if already downloaded (idempotent across re-submissions).
if [[ -f "$FASTQ_DIR/${RUN}_1.fastq.gz" || -f "$FASTQ_DIR/${RUN}.fastq.gz" ]]; then
    echo "[$(date)] $RUN already downloaded, skipping"
    exit 0
fi

echo "[$(date)] fastq-dump $RUN  (task $SLURM_ARRAY_TASK_ID)"
fastq-dump --split-files --gzip --outdir "$FASTQ_DIR" "$RUN"
echo "[$(date)] $RUN fetch complete"
